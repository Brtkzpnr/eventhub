generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Category {
  name  String  @unique
  id    Int     @id @default(autoincrement())
  Event Event[]
}

model Event {
  title       String
  description String?
  date        DateTime
  price       Float
  location    String
  id          Int      @id @default(autoincrement())
  categoryId  Int
  Category    Category @relation(fields: [categoryId], references: [id])
  imageUrl    String?
  stock:      Int 
  sold:       Int @default(0) 
}
